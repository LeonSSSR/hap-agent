# agent-service 环境变量示例（复制为 .env 后按需修改）

# --- Agentic 大模型（DeepSeek OpenAI 兼容）---
# API Key 请写在仓库根目录 /data/ai-platform/.env 的 AGENT_MODEL_API_KEY，勿写入本文件
# AGENT_MODEL_ENABLED=true
# AGENT_MODEL_PROVIDER=openai_compatible
# AGENT_MODEL_BASE_URL=https://api.deepseek.com
# AGENT_MODEL_NAME=deepseek-v4-pro
# AGENT_MODEL_TIMEOUT_SECONDS=60
# AGENT_MODEL_TEMPERATURE=0.1
# AGENT_MODEL_MAX_TOKENS=2048
# AGENT_MODEL_THINKING_ENABLED=false
# AGENT_MODEL_REASONING_EFFORT=high
# AGENT_MODEL_STREAM_ENABLED=true
# AGENT_AGENTIC_MAX_TURNS=32
# AGENT_AGENTIC_MAX_TOOLS_PER_TURN=8
# AGENT_AGENTIC_TOOLS_SCHEMA_LIMIT=36
# AGENT_AGENTIC_UI_ACTIONS_SCHEMA_LIMIT=64
# AGENT_AGENTIC_PAGE_ROOTS_SCHEMA_LIMIT=48
# AGENT_AGENTIC_PAGE_ACTIONS_SCHEMA_LIMIT=60
# AGENT_AGENTIC_UI_ACTION_DESC_MAX_CHARS=256
# AGENT_AGENTIC_UI_ACTION_GLOSSARY_MAX_CHARS=12000
# 未配置 API Key 时自动使用 MockAgenticLlm（CI/本地演示）

# 平台 API 模式：mock | live | hybrid
AGENT_PLATFORM_API_MODE=hybrid
AGENT_CORE_SERVICE_URL=http://127.0.0.1:8085
# AGENT_INTERNAL_API_TOKEN=dev-internal-token-aiplatform-2026

# 长期会话记忆（JSONL 落盘目录，留空则仅内存）
# AGENT_SESSION_STORE_PATH=data/sessions
# AGENT_RUN_STORE_PATH=data/run_state
# AGENT_SESSION_CONTEXT_WINDOW=12
# AGENT_LONG_TERM_MEMORY_ENABLED=true
# AGENT_LONG_TERM_MEMORY_SEARCH_LIMIT=5

# --- 生产安全（必须与 core-service 的 JWT_SECRET 一致）---
# AGENT_RUNTIME_ENV=production
# AGENT_JWT_SECRET=your-platform-jwt-secret
# AGENT_AUTH_REQUIRED=true
# AGENT_AUTH_DEV_BYPASS=false
# AGENT_AUTH_FETCH_PERMISSIONS=true
# AGENT_AUDIT_STORE_PATH=data/audit/audit_events.sqlite3
